from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware

app = FastAPI(title="{{projectName}} API")

app.add_middleware(
CORSMiddleware,
allow_origins=["*"],
allow_credentials=True,
allow_methods=["*"],
allow_headers=["*"],
)

@app.get("/")
def read_root():
return {"status": "ok", "message": "Backend for {{projectName}} is running!"}

@app.get("/api/health")
def health_check():
return {"status": "healthy"}