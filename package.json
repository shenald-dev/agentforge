{
    "name": "agentforge",
    "version": "2.0.14",
    "description": "Autonomous Full-Stack App Builder CLI.",
    "main": "dist/cli/index.js",
    "bin": {
        "agentforge": "./dist/cli/index.js"
    },
    "scripts": {
        "start": "node dist/cli/index.js",
        "dev": "tsx watch src/cli/index.ts",
        "build": "tsc",
        "test": "jest",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "keywords": [
        "cli",
        "scaffold",
        "generator",
        "ai",
        "vibe",
        "boilerplate"
    ],
    "author": "shenald-dev",
    "license": "MIT",
    "dependencies": {
        "@clack/prompts": "^1.3.0",
        "@langchain/core": "^1.1.42",
        "@langchain/openai": "^1.4.5",
        "commander": "^12.0.0",
        "handlebars": "4.7.9",
        "ora": "^5.4.1",
        "picocolors": "^1.1.1"
    },
    "devDependencies": {
        "@types/jest": "^29.5.12",
        "@types/node": "^20.19.39",
        "@typescript-eslint/eslint-plugin": "^7.1.0",
        "@typescript-eslint/parser": "^7.1.0",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "jest": "^29.7.0",
        "prettier": "3.8.3",
        "ts-jest": "29.4.9",
        "tsx": "^4.7.1",
        "typescript": "^5.3.3"
    }
}